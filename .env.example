# Server settings
SERVER_PORT=7777

# REQUIRED: Your server's public IP address
# Without this, the server advertises Docker's internal IP and clients cannot connect
MULTIHOME=YOUR_PUBLIC_IP

# Set to "false" to skip update check on container start
UPDATE_ON_START=true

# RCON — leave blank to disable
RCON_PORT=27015
RCON_PASSWORD=changeme

# Encrypted files are generated automatically on container start via starrupture-utilities.com
ADMIN_PASSWORD=changeme
PLAYER_PASSWORD=changeme

# Webhook URL for map-load failure alerts
DISCORD_WEBHOOK_URL=
# GitHub PAT — avoids the 60 req/hr unauthenticated API rate limit
GITHUB_TOKEN=
# Optional Seconds to wait for map load confirmation (default: `600`) 
MAP_LOAD_TIMEOUT=600

# --- Save game & session config ---
# These are NOT env vars. They live in DSSettings.txt alongside the server exe.
#
# Default (no action needed):
#   The entrypoint auto-generates DSSettings.txt with session "MySaveGame" and seeds
#   the save from AutoSave0.sav / AutoSave0.met on first run. That's it.
#
# Custom save / session:
#   1. Create your own DSSettings.txt with the correct SessionName.
#   2. Place your saves under ./Saved/<SessionName>/AutoSave0.sav
#   3. Uncomment the DSSettings.txt bind mount line in docker-compose.yml.
